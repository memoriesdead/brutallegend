ack { Name="Ranged Guitar Attack"; UtilityScaler = 3.0; MaxAttackRate = 2; MaxUtility = 5; InventorySlot=kSLOT_Melee; Charged = false; Special = false; UseCombatReservations = false; RespectAttackPermission = false; ValidDistanceRange=<6.0,30.0>; ComboStickiness = .82; UseAgainstAvatars = true; UseAgainstInfantry = true; UseAgainstVehicles = true; }, ManeuverMeleeAttack { Name="Ranged Guitar Charged Attack"; UtilityScaler = 3.0; MaxAttackRate = 2; MaxUtility = 5; InventorySlot=kSLOT_Melee; Charged = true; Special = false; UseCombatReservations = false; RespectAttackPermission = false; ValidDistanceRange=<6.0,30.0>; ComboStickiness = .2; UseAgainstAvatars = true; UseAgainstInfantry = true; UseAgainstVehicles = true; }, ManeuverMaintainDistance { MaxDistance = 2.5; IdealDistance = 2.5; DistanceRandomFactor = 0.0; UtilityScaler = 10.0; ValidDistanceRange = <2.5, 1000>; FocusOnEnemy = false; MinTimeInManeuver = 2.0; UseAgainstAvatars = true; UseAgainstInfantry = true; UseAgainstVehicles = true; }, ManeuverIdleStrafe { UtilityScaler = 1; MaxTimeInManeuver = 2.0; MinTimeInManeuver = 2.0; MaxManeuverFrequency = 3.0; MovementSpeed = 1.0; FocusOnEnemy = true; ValidDistanceRange=<1.0,3.0>; UseAgainstAvatars = true; UseAgainstInfantry = true; UseAgainstVehicles = true; }, ManeuverIdle { UtilityScaler = 1; MaxManeuverFrequency = 10.0; UseAgainstAvatars = true; UseAgainstInfantry = true; UseAgainstVehicles = true; }, ]; }; TargetBiasCurrent=1; TargetBiasDamaged=1; TargetBiasEnemyDown=-5; TargetBiasPlayer=1; TargetBiasInfantry=1; TargetBiasVehicles=1; TargetBiasBuildings=-10000; TargetBiasDistance=10; TargetBiasFacing=0; FrontalBiasAngle=45; DebugSpotlightPrototype=DebugSpotlight; SoloingDamageResponses=@Gameplay\Combat\AvatarSoloing; }; } 
